#
# ======================================================================================
# SEARCH SERVICE - ОСНОВНЫЕ НАСТРОЙКИ
# ======================================================================================
# 
# ============================================
# СЕРВЕР
# ============================================
SEARCH_SERVICE_HOST=0.0.0.0
SEARCH_SERVICE_PORT=8002
SEARCH_SERVICE_ENVIRONMENT=development
#
# ============================================
# gRPC
# ============================================
SEARCH_SERVICE_GRPC_PORT=50052
#
# ============================================
# MEILISEARCH
# ============================================
SEARCH_SERVICE_MEILISEARCH_HOST=http://localhost:7700
SEARCH_SERVICE_MEILISEARCH_API_KEY=meili-master-key-secure-change-me
SEARCH_SERVICE_MEILISEARCH_INDEX=recipes
SEARCH_SERVICE_MEILISEARCH_TIMEOUT=30
SEARCH_SERVICE_MEILISEARCH_RETRY_DELAY=5
#
# ============================================
# RABBITMQ MESSAGE BROKER
# ============================================
SEARCH_SERVICE_RABBITMQ_USER=admin
SEARCH_SERVICE_RABBITMQ_PASSWORD=rabbitmq-password
SEARCH_SERVICE_RABBITMQ_VHOST=/
SEARCH_SERVICE_RABBITMQ_URL=amqp://admin:rabbitmq-password@rabbitmq:5672/
SEARCH_SERVICE_RABBITMQ_EXCHANGE=recipe_events
SEARCH_SERVICE_RABBITMQ_QUEUE=search_service_queue
SEARCH_SERVICE_RABBITMQ_RETRY_DELAY=5
SEARCH_SERVICE_RABBITMQ_RECONNECT=5  
#
# ============================================
# ЛОГИРОВАНИЕ
# ============================================
SEARCH_SERVICE_LOG_LEVEL=INFO
SEARCH_SERVICE_LOG_FORMAT=json