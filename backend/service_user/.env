#
# ======================================================================================
# USER SERVICE - ОСНОВНЫЕ НАСТРОЙКИ
# ======================================================================================
# 
# ============================================
# СЕРВЕР
# ============================================
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8000
USER_SERVICE_ENVIRONMENT=development
#
# ============================================
# API ДОКУМЕНТАЦИЯ
# ============================================
USER_SERVICE_API_TITLE="User Service"
USER_SERVICE_API_VERSION="1.0.2"
USER_SERVICE_API_DESCRIPTION="API для управления пользователями и аутентификацией"
#
# ============================================
# АУТЕНТИФИКАЦИЯ И БЕЗОПАСНОСТЬ
# ============================================
USER_SERVICE_SECRET_KEY=your-super-secret-key
USER_SERVICE_ALGORITHM=HS256
USER_SERVICE_ACCESS_TOKEN_EXPIRE_MINUTES=15
USER_SERVICE_REFRESH_TOKEN_EXPIRE_DAYS=30
# Пароли
USER_SERVICE_MIN_PASSWORD_LENGTH=8
USER_SERVICE_MAX_PASSWORD_LENGTH=128
USER_SERVICE_REQUIRE_UPPERCASE=true
USER_SERVICE_REQUIRE_LOWERCASE=true
USER_SERVICE_REQUIRE_DIGITS=true
USER_SERVICE_REQUIRE_SPECIAL_CHARS=true
#
# ============================================
# CORS НАСТРОЙКИ
# ============================================
# USER_SERVICE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
USER_SERVICE_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://127.0.0.1:8001","http://localhost:8001"]
USER_SERVICE_CORS_ALLOW_CREDENTIALS=true
#
# ============================================
# gRPC НАСТРОЙКИ
# ============================================
USER_SERVICE_GRPC_ENABLED=true
USER_SERVICE_GRPC_PORT=50051
#
#
#
#
# ======================================================================================
# DATABASE 
# ======================================================================================
# 
# ============================================
# ОБЩИЕ НАСТРОЙКИ
# ============================================
DB_HOST=postgres_user
DB_PORT=5432
POSTGRES_DB=users_db
POSTGRES_USER=user_service
POSTGRES_PASSWORD=258075
DB_DRIVER=postgresql+psycopg2
#
# ============================================
# СЕРВЕР
# ============================================
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=8000
DB_SERVICE_WORKERS=1
#
# ============================================
# ОКРУЖЕНИЕ И РЕЖИМ ОТЛАДКИ
# ============================================
DEBUG=True
TESTING=False
#
# ============================================
# НАСТРОЙКИ ПУЛА СОЕДИНЕНИЙ
# ============================================
POOL_SIZE=10
MAX_OVERFLOW=20

