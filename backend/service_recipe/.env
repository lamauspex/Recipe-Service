#
# ======================================================================================
# RECIPE SERVICE - ОСНОВНЫЕ НАСТРОЙКИ
# ======================================================================================
# 
# ============================================
# СЕРВЕР
# ============================================
RECIPE_SERVICE_HOST=0.0.0.0
RECIPE_SERVICE_PORT=8001
RECIPE_SERVICE_ENVIRONMENT=development
#
# ============================================
# API ДОКУМЕНТАЦИЯ
# ============================================
RECIPE_SERVICE_API_DOCS_ENABLED=true
RECIPE_SERVICE_API_TITLE="Recipe Service"
RECIPE_SERVICE_API_VERSION="1.0.0"
RECIPE_SERVICE_API_DESCRIPTION="API для управления рецептами"
#
# ============================================
# RABBITMQ MESSAGE BROKER
# ============================================
RECIPE_SERVICE_RABBITMQ_USER=admin
RECIPE_SERVICE_RABBITMQ_PASSWORD=rabbitmq-password
RECIPE_SERVICE_RABBITMQ_VHOST=/
RECIPE_SERVICE_RABBITMQ_URL=amqp://admin:rabbitmq-password@rabbitmq:5672/
#
# ============================================
# GRPC_HOST
# ============================================
RECIPE_SERVICE_GRPC_HOST=service_user  
RECIPE_SERVICE_GRPC_PORT=50051
#
RECIPE_SERVICE_JWT_ALGORITHM=HS256
#
# ============================================
# API Keys для других сервисов
# ============================================
RECIPE_SERVICE_U_S_API_KEY=user-service-secret-key
RECIPE_SERVICE_JWT_SECRET_KEY=your-jwt-secret-key
#
# ============================================
# ЛОГИРОВАНИЕ
# ============================================
USER_SERVICE_LOG_LEVEL=INFO
USER_SERVICE_LOG_FORMAT=text
USER_SERVICE_STRUCTURED_LOGGING=true
USER_SERVICE_ENABLE_REQUEST_LOGGING=True
USER_SERVICE_ENABLE_EXCEPTION_LOGGING=True
USER_SERVICE_ENABLE_BUSINESS_LOGGING=True
#
#
#
#
#
# ======================================================================================
# DATABASE SERVICE - ОСНОВНЫЕ НАСТРОЙКИ
# ======================================================================================
# 
# ============================================
# ОБЩИЕ НАСТРОЙКИ
# ============================================
DB_HOST=postgres_recipe
DB_PORT=5432
DB_NAME=recipe_db
DB_USER=recipe_service
DB_PASSWORD=258074
DB_DRIVER=postgresql+psycopg2
#
# ============================================
# СЕРВЕР
# ============================================
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=8000
DB_SERVICE_WORKERS=1
#
# ============================================
# ОКРУЖЕНИЕ И РЕЖИМ ОТЛАДКИ
# ============================================
DEBUG=True
TESTING=False
SERVICE_ENVIRONMENT=development
#
# ============================================
# НАСТРОЙКИ ПУЛА СОЕДИНЕНИЙ
# ============================================
POOL_SIZE=10
MAX_OVERFLOW=20
#
# ============================================
# Для postgres контейнера
# ============================================
POSTGRES_USER=recipe_service
POSTGRES_PASSWORD=258074
POSTGRES_DB=recipe_db
