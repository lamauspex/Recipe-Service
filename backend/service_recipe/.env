#
# ======================================================================================
# DATABASE SERVICE - ОСНОВНЫЕ НАСТРОЙКИ
# ======================================================================================
# 
# ============================================
# БАЗА ДАННЫХ (ОБЩИЕ НАСТРОЙКИ)
# ============================================
DB_HOST=postgres_recipe
DB_PORT=5435
DB_NAME=recipe_db
DB_USER=recipe_service
DB_PASSWORD=258074
DB_DRIVER=postgresql+psycopg2

# ============================================
# БЕЗОПАСНОСТЬ (API Keys для других сервисов)
# ============================================
SERVICE_USER_SERVICE_API_KEY=user-service-secret-key
SERVICE_RECIPE_SERVICE_API_KEY=recipe-service-secret-key
SERVICE_JWT_SECRET_KEY=your-jwt-secret-key

# ============================================
# СЕРВЕР
# ============================================
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=8000
DB_SERVICE_WORKERS=1

# ============================================
# ОКРУЖЕНИЕ И РЕЖИМ ОТЛАДКИ
# ============================================
DEBUG=True
TESTING=False
SERVICE_ENVIRONMENT=development

# ============================================
# НАСТРОЙКИ ПУЛА СОЕДИНЕНИЙ
# ============================================
POOL_SIZE=10
MAX_OVERFLOW=20

# ============================================
# Для postgres контейнера
# ============================================
POSTGRES_USER=recipe_service
POSTGRES_PASSWORD=258074
POSTGRES_DB=recipe_db
