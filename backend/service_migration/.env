# ============================================
# БАЗА ДАННЫХ (ОБЩИЕ НАСТРОЙКИ)
# ============================================
DATABASE_SERVICE_DB_HOST=postgres
DATABASE_SERVICE_DB_PORT=5432
DATABASE_SERVICE_DB_NAME=recipe_db
DATABASE_SERVICE_DB_USER=postgres
DATABASE_SERVICE_DB_PASSWORD=258074
DATABASE_SERVICE_DB_DRIVER=postgresql+psycopg2

# ============================================
# БЕЗОПАСНОСТЬ (API Keys для других сервисов)
# ============================================
DATABASE_SERVICE_SERVICE_USER_SERVICE_API_KEY=user-service-secret-key
DATABASE_SERVICE_SERVICE_RECIPE_SERVICE_API_KEY=recipe-service-secret-key
DATABASE_SERVICE_SERVICE_JWT_SECRET_KEY=your-jwt-secret-key

# ============================================
# СЕРВЕР
# ============================================
DB_SERVICE_HOST=0.0.0.0
DB_SERVICE_PORT=8000
DB_SERVICE_WORKERS=1

# ============================================
# ОКРУЖЕНИЕ И РЕЖИМ ОТЛАДКИ
# ============================================
DATABASE_SERVICE_DEBUG=True
DATABASE_SERVICE_TESTING=False
DATABASE_SERVICE_SERVICE_ENVIRONMENT=development

# ============================================
# НАСТРОЙКИ ПУЛА СОЕДИНЕНИЙ
# ============================================
DATABASE_SERVICE_POOL_SIZE=10
DATABASE_SERVICE_MAX_OVERFLOW=20

