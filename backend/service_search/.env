# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8002

# gRPC
GRPC_PORT=50052

# MeiliSearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=meili-master-key-secure-change-me
MEILISEARCH_INDEX=recipes
MEILISEARCH_TIMEOUT=30

# RabbitMQ
RABBITMQ_URL=amqp://admin:rabbitmq-password@localhost:5672/
RABBITMQ_EXCHANGE=recipe_events
RABBITMQ_QUEUE=search_service_queue

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
